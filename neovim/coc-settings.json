            "-vendor",
            "-docs",
            "-scripts"
        ]
    },
    "rust-analyzer.inlayHints.typeHints": false,
    "rust-analyzer.completion.addCallArgumentSnippets": false,
    "smartf.jumpOnTrigger": false,
    "smartf.wordJump": false,
    "python.linting.enabled": true,
    "list.source.symbols.excludes": [
        "/Users/rain/go/pkg/mod/**",
        "/usr/local/go/**",
        "/Users/rain/Library/**"
    ],
    "list.source.outline.ctagsFilestypes": [
        "markdown",
        "md"
    ],
    "imselect.enableFloating": false,
    "imselect.defaultInput": "com.apple.keylayout.ABC",
    "imselect.enableStatusItem": true,
    "python.analysis.typeCheckingMode": "off"
